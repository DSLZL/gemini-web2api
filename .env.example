# gemini-web2api environment template
# Copy to .env and adjust values for your environment.

# ---------------------------
# Variables used by current Go runtime
# ---------------------------

# Server listen address (equivalent to host + port in config.example.json)
GEMINI_WEB2API_ADDR=:8081

# Resin proxy integration
RESIN_ENDPOINT=http://127.0.0.1:2260
RESIN_MODE=reverse
RESIN_AUTH_VERSION=V1
RESIN_PLATFORM=platform_a
RESIN_ACCOUNT=account_a
RESIN_PROXY_TOKEN=

# Optional system proxy (equivalent to old proxy field)
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1

# ---------------------------
# Common client-side variables (optional)
# ---------------------------

# For OpenAI SDK / CLI pointing to this service
GEMINI_API_KEY=none
GOOGLE_GEMINI_BASE_URL=http://localhost:8081

# ---------------------------
# Migration map from config.example.json
# ---------------------------
# port + host            -> GEMINI_WEB2API_ADDR
# proxy                  -> HTTP_PROXY / HTTPS_PROXY
# cookie_file            -> deprecated (anonymous mode only)
#
# The following legacy fields are not wired in current Go runtime.
# Keep them as migration placeholders:
# retry_attempts         -> GEMINI_WEB2API_RETRY_ATTEMPTS
# retry_delay_sec        -> GEMINI_WEB2API_RETRY_DELAY_SEC
# request_timeout_sec    -> GEMINI_WEB2API_REQUEST_TIMEOUT_SEC
# default_model          -> GEMINI_WEB2API_DEFAULT_MODEL
# log_requests           -> GEMINI_WEB2API_LOG_REQUESTS
GEMINI_WEB2API_RETRY_ATTEMPTS=3
GEMINI_WEB2API_RETRY_DELAY_SEC=2
GEMINI_WEB2API_REQUEST_TIMEOUT_SEC=180
GEMINI_WEB2API_DEFAULT_MODEL=gemini-3.5-flash
GEMINI_WEB2API_LOG_REQUESTS=true
